#!/usr/bin/env bash
# Refuses commits made directly on main/master (CLAUDE.md: repo conventions).
# Enabled via `just setup-hooks` (git config core.hooksPath scripts/git-hooks).
set -euo pipefail

branch=$(git rev-parse --abbrev-ref HEAD)

if [[ "$branch" == "main" || "$branch" == "master" ]]; then
    echo "error: direct commits to '$branch' are not allowed." >&2
    echo "Create a branch first, e.g.:" >&2
    echo "  git checkout -b type/scope-description" >&2
    echo "then commit there and open a PR." >&2
    exit 1
fi
