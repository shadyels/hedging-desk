{
  "type": "record",
  "name": "Trade",
  "namespace": "hedging.posttrade.v1",
  "doc": "Booked trade (external fill leg or internal cross leg). Topic: posttrade.trades, key: instrument_id. Fixed-point per protocol/CLAUDE.md: px_e9 = price*1e9, qty_e2 = qty*1e2.",
  "fields": [
    {"name": "msg_id", "type": "string", "doc": "UUIDv7; consumers dedupe"},
    {"name": "trade_id", "type": "string"},
    {"name": "booked_ns", "type": "long"},
    {"name": "book_id", "type": "int"},
    {"name": "instrument_id", "type": "int"},
    {"name": "symbol", "type": "string"},
    {"name": "side", "type": {"type": "enum", "name": "Side", "symbols": ["BUY", "SELL"]}},
    {"name": "qty_e2", "type": "long"},
    {"name": "px_e9", "type": "long"},
    {"name": "currency", "type": "string"},
    {"name": "trade_kind", "type": {"type": "enum", "name": "TradeKind", "symbols": ["EXTERNAL_FILL", "INTERNAL_CROSS_LEG"]}},
    {"name": "cross_id", "type": ["null", "string"], "default": null, "doc": "set for INTERNAL_CROSS_LEG"},
    {"name": "parent_cl_ord_id", "type": ["null", "string"], "default": null, "doc": "set for EXTERNAL_FILL"},
    {"name": "exec_id", "type": ["null", "string"], "default": null},
    {"name": "counterparty", "type": "string", "doc": "'INTERNAL' for cross legs; venue/broker id otherwise"}
  ]
}
